# Runtime defaults for spawned Codex workers.
ORCHESTRATOR_CODEX_SANDBOX_MODE=danger-full-access
ORCHESTRATOR_CODEX_APPROVAL_POLICY=never
ORCHESTRATOR_CODEX_NETWORK_ACCESS_ENABLED=true

# Runtime defaults for spawned Claude workers.
ORCHESTRATOR_CLAUDE_PERMISSION_MODE=bypassPermissions
ORCHESTRATOR_CLAUDE_ALLOW_DANGEROUSLY_SKIP_PERMISSIONS=true
