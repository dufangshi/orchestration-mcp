{
  "name": "nanobot-orchestration-mcp",
  "version": "0.1.0",
  "description": "Local MCP server for orchestrating external coding agent runs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orchestrator": "./orchestrator",
    "peer": "./peer"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "start:a2a-agent": "npm run build && node dist/test-agents/start-a2a-agent.js",
    "test": "npm run build && node --test"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.12",
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex-sdk": "^0.112.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
